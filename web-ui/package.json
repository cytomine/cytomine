{
  "name": "cytomine-web-ui",
  "description": "A web-based user interface for interacting with Cytomine.",
  "version": "3.2.0",
  "homepage": "https://uliege.cytomine.org/",
  "license": "Apache-2.0",
  "scripts": {
    "serve": "npm run watch-translations & vue-cli-service serve",
    "build": "npm run translations-csv2json && vue-cli-service build",
    "lint": "eslint -c .eslintrc.js --ext .js,.vue --ignore-path .gitignore .",
    "test:unit": "jest",
    "translations-csv2json": "node scripts/export_i18n_csv.mjs src/locales/translations.csv src/locales/json",
    "watch-translations": "onchange -i 'src/locales/translations.csv' -- npm run translations-csv2json",
    "watch": "npm-watch"
  },
  "dependencies": {
    "@ckpack/vue-color": "^1.6.0",
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@kyvg/vue3-notification": "^3.4.2",
    "@ntohq/buefy-next": "^0.2.0",
    "axios": "^1.16.0",
    "bulma": "^0.9.4",
    "bulma-slider": "^2.0.0",
    "chart.js": "^2.9.4",
    "chartjs-plugin-datalabels": "^0.6.0",
    "chartjs-plugin-zoom": "^0.7.4",
    "copy-to-clipboard": "^3.0.8",
    "core-js": "^3.6.5",
    "detect-browser": "^4.7.0",
    "filesize": "^4.1.2",
    "floating-vue": "^5.2.2",
    "html2canvas": "^1.4.1",
    "ifvisible": "^1.1.0",
    "keycloak-js": "^24.0.4",
    "lodash": "^4.18.1",
    "mitt": "^3.0.1",
    "moment": "^2.29.4",
    "npm-font-open-sans": "^1.1.0",
    "ol": "^5.3.1",
    "ol-rescale-feature": "^1.0.0",
    "ol-rotate-feature": "^2.0.1",
    "quill": "^1.3.7",
    "sl-vue-tree-next": "^0.0.14",
    "vue": "^3.5.13",
    "vue-draggable-resizable": "^3.0.0",
    "vue-i18n": "^9.14.0",
    "vue-multiselect": "^3.5.0",
    "vue-router": "^4.4.0",
    "vue-slider-component": "^4.1.0-beta.7",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@vue/cli-plugin-babel": "^5.0.8",
    "@vue/cli-plugin-eslint": "^5.0.8",
    "@vue/cli-service": "^5.0.8",
    "@vue/test-utils": "^2.4.6",
    "@vue/vue3-jest": "^29.2.6",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^8.57.1",
    "eslint-plugin-jest": "^26.8.0",
    "eslint-plugin-vue": "^9.28.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-html-reporter": "^4.1.0",
    "onchange": "^7.1.0",
    "randomstring": "^1.1.5",
    "sass": "^1.86.0",
    "sass-loader": "^8.0.2"
  },
  "postcss": {
    "plugins": {
      "autoprefixer": {}
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ]
}
